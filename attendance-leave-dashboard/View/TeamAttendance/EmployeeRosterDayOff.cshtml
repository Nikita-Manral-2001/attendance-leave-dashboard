@model TTH.Areas.Super.Models.TeamAttendance.EmployeeViewModel



<style>


     .highlight {
       background-color: #ffc000;
       font-weight: bold;
     }

    .MainPart {
        background-color: #fffbe6;
        font-size: 12px;
        margin-left: 40px;
        padding: 20px;
        overflow-x: hidden;
    }



     h2 {
       font-size: 20px;
       margin-left:45px;
     }
    @{
        var leaveList = ViewBag.OperationleaveCount as List<TTH.Areas.Super.Models.TeamAttendance.LeaveCountViewModel>;

    }

</style>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card card-primary card-outline">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-list"></i>
                          Add Employee Roster Day
                        </h3>
                    </div>
    <div class="MainPart">
        <div class="row mt-4">
            <div class="col-md-4">
                <form class="p-4 shadow rounded bg-white" method="post" onsubmit="return validateForm()" asp-controller="TeamAttendance" asp-action="AddRosterLeaves">
                    <div class="mb-3">
                        <label for="employeeSelect" class="form-label fw-semibold">Select Employee</label>
                        <select id="employeeSelect" name="employeeData" class="form-select form-select-sm border-3" aria-label="Select Employee" required>
                            <option value="" selected>Select Emp---</option>
                            @foreach (var emp in Model.Employees)
                            {
                                <option value="@emp.EmployeeId" name="employeeData">@emp.FirstName @emp.LastName (@emp.EmployeeId)</option>
                            }
                        </select>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="startDate" class="form-label fw-semibold">Roster Date</label>
                            <input type="date" id="startDate" name="rosterDate" class="form-control form-control-sm border-3" required />
                        </div>
                        <div class="col-md-6">
                            <label for="endDate" class="form-label fw-semibold">Leave Date</label>
                            <input type="date" id="endDate" name="leaveDate" class="form-control form-control-sm border-3" required/>
                        </div>
                    </div>

                   

                    
                    <div class="mb-4">
                        <label for="note" class="form-label fw-semibold">Note</label>
                        <input type="text" id="note" name="note" class="form-control form-control-sm border-3" placeholder="Add a note (optional)" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-danger btn-sm fw-semibold">Submit</button>
                    </div>
                </form>


            </div>

            <div class="col-md-8">
                @if (Model.Roster != null)
                {
                    <table class="table table-bordered">
                        <thead class="table-warning">
                            <tr>
                                <th>EMPLOYEE ID</th>
                                 <th>EMPLOYEE NAME</th> 
                                <th>Roster DATE</th>
                                <th>Leave DATE</th>
                              
                                <th>Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var leave in Model.Roster)
                            {
                                <tr>
                                    <td><span class="view-mode">@leave.EmployeeId</span><input type="number" class="form-control edit-mode employee-id" value="@leave.EmployeeId" style="display: none;"></td>
                                     <td><span class="view-mode">@leave.FirstName @leave.LastName</span><input type="text" class="form-control edit-mode full-name" value="@leave.FirstName @leave.LastName" style="display: none;"></td>
     <td>
    <span class="view-mode">@leave.RosterDate.ToString("dd-MM-yyyy")</span>
    <input type="date"
           class="form-control edit-mode start-date"
          value="@(leave.RosterDate != null ? leave.RosterDate.ToString("yyyy-MM-dd") : "")"
           style="display: none;" />
</td>
<td>
    <span class="view-mode">@leave.LeaveDate.ToString("dd-MM-yyyy")</span>
    <input type="date"
           class="form-control edit-mode end-date"
           value="@(leave.LeaveDate != null ? leave.LeaveDate.ToString("yyyy-MM-dd") : "")"
           style="display: none;" />
</td>
                                   
                                    <td><span class="view-mode">@leave.Note</span><input type="text" class="form-control edit-mode note" value="@leave.Note" style="display: none;"></td>




                                    <td>
                                        <button type="button" class="btn btn-primary btn-sm edit-btn fas fa-edit" data-id="@leave.Id"></button>
                                        <button type="button" class="btn btn-success btn-sm update-btn" data-id="@leave.Id" style="display: none;">Update</button>
                                        <button type="button" class="btn btn-danger btn-sm delete-btn fas fa-trash-alt" data-id="@leave.Id"></button>
                                        <button type="button" class="btn btn-secondary btn-sm cancel-btn" data-id="@leave.Id" style="display: none;">Cancel</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
    </div>
    </div>
    </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        // Handle Delete button
        document.querySelectorAll(".delete-btn").forEach(button => {
            button.addEventListener("click", function () {
                var id = this.getAttribute("data-id");
                console.log("yes");
                if (confirm("Are you sure you want to delete this leave?")) {
                    fetch(`/super/TeamAttendance/DeleteRosterData/${id}`, {
                        method: 'DELETE',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        }
                    })
                        .then(response => {
                            if (response.ok) {
                                location.reload();
                            } else {
                                alert('Failed to delete the leave.');
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        });

        // Handle Edit button
        document.querySelectorAll(".edit-btn").forEach(button => {
            button.addEventListener("click", function () {
                var row = this.closest("tr");
                row.querySelectorAll(".view-mode").forEach(el => el.style.display = "none");
                row.querySelectorAll(".edit-mode").forEach(el => el.style.display = "block");
                row.querySelector(".edit-btn").style.display = "none";
                row.querySelector(".update-btn").style.display = "inline-block";
                row.querySelector(".delete-btn").style.display = "none";
                row.querySelector(".cancel-btn").style.display = "inline-block";
            });
        });

        // Handle Cancel button
        document.querySelectorAll(".cancel-btn").forEach(button => {
            button.addEventListener("click", function () {
                var row = this.closest("tr");
                row.querySelectorAll(".view-mode").forEach(el => el.style.display = "block");
                row.querySelectorAll(".edit-mode").forEach(el => el.style.display = "none");
                row.querySelector(".edit-btn").style.display = "inline-block";
                row.querySelector(".update-btn").style.display = "none";
                row.querySelector(".delete-btn").style.display = "inline-block";
                row.querySelector(".cancel-btn").style.display = "none";
            });
        });

        document.querySelectorAll(".update-btn").forEach(button => {
            button.addEventListener("click", function () {
                const row = this.closest("tr");
                const id = this.getAttribute("data-id");

                const updatedData = {
                    Id: id,
                    EmployeeId: row.querySelector(".employee-id").value,
                    FullName: row.querySelector(".full-name").value,
                    StartDate: row.querySelector(".start-date").value,
                    EndDate: row.querySelector(".end-date").value,
                    
                    Note: row.querySelector(".note").value
                };

                fetch(`/super/TeamAttendance/UpdateRosterData`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(updatedData)
                })
                    .then(response => {
                        if (response.ok) {
                            alert("Leave updated successfully.");
                            location.reload();
                        } else {
                            alert("Failed to update leave.");
                        }
                    })
                    .catch(error => console.error("Error:", error));
            });
        });
    });
    
    </script>

