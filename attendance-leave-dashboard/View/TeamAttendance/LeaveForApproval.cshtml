@model List<TTH.Areas.Super.Models.TeamAttendance.EmployeeLeaveVM>



<style>


    .highlight {
        background-color: #ffc000;
        font-weight: bold;
    }

    .MainPart {
        background-color: #fffbe6;
        font-size: 12px;
        margin-left: 20px;
        margin-right: 20px;
        padding: 20px;
        overflow-x: hidden;
    }



    h2 {
        font-size: 20px;
        margin-left: 45px;
    }

</style>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card card-primary card-outline">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-list"></i>
                            Leave For Approval
                        </h3>
                    </div>
                    <div class="MainPart">
                        <div class="row mt-4">
                            <div class="col-md-12">

                                <table class="table table-bordered">
                                    <thead class="table-warning">
                                        <tr>
                                            <th>EMPLOYEE Id</th>
                                            <th>EMPLOYEE NAME</th>
                                            <th>START DATE</th>
                                            <th>END DATE</th>
                                            <th>Leave</th>
                                            <th>Note</th>
                                            <th>Remarks</th>
                                            <th>Action</th>
                                            <th>Pending Leaves</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var emp in Model)
                                        {
                                            <tr>
                                                <td>@emp.Leave.EmployeeId</td>
                                                <td>@emp.Leave.FirstName @emp.Leave.LastName</td>
                                                <td>@emp.Leave.StartDate?.ToString("dd-MM-yyyy")</td>
                                                <td>@emp.Leave.EndDate?.ToString("dd-MM-yyyy")</td>
                                                <td>@emp.Leave.Leave</td>
                                                <td>@emp.Leave.Note</td>
                                                <td>
                                                    <textarea class="form-control remarks-text" rows="3" cols="30" placeholder="Enter your remarks here">@emp.Leave.NoteByHR</textarea>
                                                </td>

                                                <td>
                                                    <!-- Document Section -->
                                                    <div style="margin-bottom:8px;">
                                                        @if (emp.Document != null)
                                                        {
                                                            <a href="@Url.Content(emp.Document.FilePath)"
                                                               target="_blank"
                                                               class="text-primary"
                                                               style="font-weight:600;">
                                                                View Attachment
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <span>No Document</span>
                                                        }
                                                    </div>

                                                    <!-- Approve / Reject Buttons -->
                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-success btn-sm approve-btn"
                                                                data-id="@emp.Leave.Id"
                                                                data-leave="@emp.Leave.Leave">
                                                            Approve
                                                        </button>

                                                        <button class="btn btn-danger btn-sm reject-btn"
                                                                data-id="@emp.Leave.Id"
                                                                data-leave="@emp.Leave.Leave">
                                                            Reject
                                                        </button>
                                                    </div>
                                                </td>

                                                <td style="color: red;"><strong>@emp.Leave.PendingLeaves</strong></td>
                                                <td>


                                                    <button type="button" class="btn btn-danger btn-sm delete-btn fas fa-trash-alt " data-id="@emp.Leave.Id"></button>

                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


    <script>
        $(document).ready(function () {

            $('.approve-btn').click(function (e) {
                e.preventDefault();

                // Define the clicked button
                var btn = $(this);
                var id = btn.data('id');
                var leave = btn.data('leave');
                var remarks = btn.closest("tr").find(".remarks-text").val();

                updateLeaveStatus(id, leave, 'Approved', remarks);
            });

            $('.reject-btn').click(function (e) {
                e.preventDefault();

                // Define the clicked button
                var btn = $(this);
                var id = btn.data('id');
                var leave = btn.data('leave');
                var remarks = btn.closest("tr").find(".remarks-text").val();

                updateLeaveStatus(id, leave, 'Rejected', remarks);
            });

            function updateLeaveStatus(id, leave, status, remarks) {
                $.ajax({
                    url: '/super/TeamAttendance/UpdateLeaveApproval',
                    type: 'POST',
                    data: { id: id, leave: leave, status: status, remarks: remarks },
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert("Something went wrong!");
                        }
                    },
                    error: function () {
                        alert("Error occurred while updating leave status.");
                    }
                });
            }
        });
    </script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";
        const tableBody = document.getElementById("leaveTableBody");
        const loadMoreBtn = document.getElementById("loadMoreBtn");

        // --------------------------
        // DELETE, EDIT, UPDATE, etc.
        // --------------------------
        document.addEventListener("click", function (e) {
            const btn = e.target.closest("button");
            if (!btn) return;

            // --- DELETE ---
            if (btn.classList.contains("delete-btn")) {
                const id = btn.dataset.id;

                if (confirm("Are you sure you want to delete this leave?")) {
                    fetch(`/super/TeamAttendance/DeleteEmployeeLeave/${id}`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "RequestVerificationToken": token
                        }
                    })
                    .then(r => {
                        if (r.ok) {
                            location.reload();
                        } else {
                            alert("Failed to delete the leave.");
                        }
                    })
                    .catch(err => console.error("Error:", err));
                }
            }
        });
    });
</script>


