 @model TTH.Areas.Super.Models.TeamAttendance.EmployeeViewModel



<style>
    .table-bordered td, .table-bordered th {
        vertical-align: middle;
        text-align: center;
        height: 40px;
        padding: 4px;
    }

    .highlight {
        background-color: #ffc000;
        font-weight: bold;
    }

    .MainPart {
        background-color: #fffbe6;
        font-size: 12px;
        margin-left: 40px;
        padding: 20px;
        overflow-x: hidden;
    }



    h2 {
        font-size: 20px;
        margin-left: 45px;
    }

    .background {
        height: 300px;
    }

    .MainBorder {
        background-color: #fdbeb1;
        font-size: 15px;
    }

</style>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card card-primary card-outline">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-list"></i>
                            Add Weekend Leave
                        </h3>
                    </div>
                    <div class="MainPart">
                        <form method="post" id="leaveForm" onsubmit="return validateForm()" asp-controller="TeamAttendance" asp-action="AddEmployeeWeekendLeaves">


                            <div class="row mt-4">


                                <div class="col-md-2">

                                    <table class="table table-bordered">
                                        <thead class="table-warning">
                                            <tr>
                                                <th>Select Weekend</th>


                                            </tr>
                                        </thead>

                                        <tbody>
                                            <tr><td class="day-cell">Sunday</td></tr>
                                            <tr><td class="day-cell">Monday</td></tr>
                                            <tr><td class="day-cell">Tuesday</td></tr>
                                            <tr><td class="day-cell">Wednesday</td></tr>
                                            <tr><td class="day-cell">Thursday</td></tr>
                                            <tr><td class="day-cell">Friday</td></tr>
                                            <tr><td class="day-cell">Saturday</td></tr>
                                        </tbody>
                                    </table>

                                    <!-- Hidden input to store selected days (can be submitted with form) -->
                                    <input type="hidden" id="selectedDays" name="selectedDays" required />


                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <div class="row">
                                            <label for="seasoneOrYearSelect" class="form-label fw-semibold MainBorder">Select Seasone Or Year</label>
                                        </div>

                                        <select id="seasoneOrYearSelect" name="seasoneOrYearData" class="form-select form-select-sm border-3" aria-label="Select Seasone Or Year" required>
                                            <option value="" selected>Select Seasone Or Year---</option>
                                            <option value="seasone">Seasone</option>
                                            <option value="year">Round of the Year</option>
                                        </select>
                                    </div>

                                    <div class="mb-3" id="seasoneDropdown" style="display:none;">
                                        <div class="row">
                                            <label for="seasoneSelect" class="form-label fw-semibold MainBorder">Select Seasone</label>
                                        </div>

                                        <select id="seasoneSelect" name="seasoneData" class="form-select form-select-sm border-3" aria-label="Select Seasone">
                                            <option value="" selected>Select Seasone---</option>
                                            <option value="seasone1">Seasone1</option>
                                            <option value="seasone2">Seasone2</option>
                                            <option value="seasone3">Seasone3</option>
                                        </select>
                                    </div>

                                    <div class="mb-3 ">
                                        <div class="row">
                                            <label for="employeeSelect" class="form-label fw-semibold MainBorder">Select Team</label>
                                        </div>

                                        <select id="employeeSelect" name="employeeData" class="form-select form-select-sm border-3 background" aria-label="Select Employee" multiple required>
                                            <option value="" selected disabled>Select Emp---</option>
                                            <optgroup label="Office Team">
                                                @foreach (var emp in Model.Employees)
                                                {
                                                    <option value="@emp.EmployeeId">@emp.FirstName @emp.LastName (@emp.EmployeeId)</option>
                                                }
                                            </optgroup>
                                            <optgroup label="Operation Team">
                                                @foreach (var emp in Model.OperationEmployees)
                                                {
                                                    <option value="@emp.EmployeeId">@emp.FirstName @emp.LastName (@emp.EmployeeId)</option>
                                                }
                                            </optgroup>

                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <div class="row">
                                            <label for="Weekenddays" class="form-label fw-semibold MainBorder">Select Days</label>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-2"> <label><input type="checkbox" name="days" value="1"> 1st</label><br></div>
                                            <div class="col-md-2"> <label><input type="checkbox" name="days" value="2"> 2nd</label><br></div>
                                            <div class="col-md-2"> <label><input type="checkbox" name="days" value="3"> 3rd</label><br></div>
                                            <div class="col-md-2"> <label><input type="checkbox" name="days" value="4"> 4th</label><br></div>
                                            <div class="col-md-2"> <label><input type="checkbox" name="days" value="All"> All</label><br></div>
                                        </div>
                               
                                    </div>


                                    <div id="ChooseDate" style="display:none;">
                                        <div>
                                            <div class="row">
                                                <label for="startDate" class="form-label fw-semibold MainBorder">Start Date</label>
                                            </div>


                                            <input type="date" id="startDate" name="startDate" class="form-control form-control-sm border-3" />
                                        </div>
                                        <div>
                                            <div class="row">
                                                <label for="endDate" class="form-label fw-semibold MainBorder">End Date</label>
                                            </div>

                                            <input type="date" id="endDate" name="endDate" class="form-control form-control-sm border-3" />
                                        </div>
                                    </div>
                                    <br />


                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-danger btn-sm fw-semibold">Submit</button>
                                    </div>



                                </div>
                                <div class="col-md-6">
                                    <table class="table table-bordered">
                                        <thead class="table-warning">
                                            <tr>
                                                <th>Season 1</th>
                                                <th>Season 2</th>
                                                <th>Season 3</th>

                                                <th>Round Of Year</th>
                                            </tr>
                                        </thead>


                                        @{
                                            var seasons = new[] { "seasone1", "seasone2", "seasone3", "unassigned" };
                                            var seasonEntries = new Dictionary<string, List<dynamic>>();

                                            // Group season entries
                                            foreach (var season in seasons)
                                            {
                                                if (season == "unassigned")
                                                {
                                                    seasonEntries[season] = Model.TeamWeekendLeaves
                                                    .Where(e => e.Seasone == null)
                                                    .ToList<dynamic>();
                                                }
                                                else
                                                {
                                                    seasonEntries[season] = Model.TeamWeekendLeaves
                                                    .Where(e => e.Seasone == season)
                                                    .ToList<dynamic>();
                                                }
                                            }
                                            // Find the maximum number of rows needed per column
                                            int maxRows = seasonEntries.Values
                                            .Select(entries => entries.Sum(e => (e.TeamMemberWeekendOff?.Count ?? 0) + 1))
                                            // +1 for date row
                                            .Max();

                                        }

                                        <tbody>
                                            <!-- Table rows -->
                                            @for (int rowIndex = 0; rowIndex < maxRows; rowIndex++)
                                            {
                                                <tr>

                                                    @foreach (var season in seasons)
                                                    {
                                                        var entries = seasonEntries[season];
                                                        int runningRow = 0;
                                                        bool cellFilled = false;

                                                        foreach (var entry in entries)
                                                        {
                                                                                                                         
    string weekendName = entry.Weekend; // e.g., "Sunday"
    string[] occurrences = entry.WeekendDays?.Split(',') ?? new string[0];

    // Convert 1 => 1st, 2 => 2nd, etc.
    Func<string, string> ordinal = n =>
    {
        if (int.TryParse(n.Trim(), out int num))
        {
            return num switch
            {
                1 => "1st",
                2 => "2nd",
                3 => "3rd",
                _ => $"{num}th"
            };
        }
        return n;
    };

    string readable = string.Join(" & ", occurrences.Select(o => $"{ordinal(o)} {weekendName}"));

                                                            // Row for date range
                                                            if (runningRow == rowIndex)
                                                            {
   
<td style="background-color: yellow;">
    @entry.StartDate?.ToString("dd MMM yy") to @entry.EndDate?.ToString("dd MMM yy") - @readable
</td>
                                                                @* <td style="background-color: yellow;">
                                                                    @entry.StartDate?.ToString("dd MMM yy") to @entry.EndDate?.ToString("dd MMM yy") - (@entry.Weekend)
                                                                </td> *@
                                                                cellFilled = true;
                                                                break;
                                                            }

                                                            runningRow++;

                                                            // Rows for members
                                                            var members = entry.TeamMemberWeekendOff as List<TTH.Areas.Super.Data.TeamAttendance.TeamMemberWeekendOff> ?? new List<TTH.Areas.Super.Data.TeamAttendance.TeamMemberWeekendOff>();


                                                            for (int m = 0; m < members.Count; m++)
                                                            {
                                                                if (runningRow == rowIndex)
                                                                {
                                                                    var member = members[m];
                                                                    <td>
                                                                        @member.FirstName @member.LastName (@member.EmployeeId)
                                                                        <button type="button" class="btn btn-danger btn-sm delete-btn fas fa-trash-alt"
                                                                                data-id="@member.Id" data-emp-id="@member.EmployeeId"></button>
                                                                    </td>
                                                                    cellFilled = true;
                                                                    break;
                                                                }
                                                                runningRow++;
                                                            }

                                                            if (cellFilled) break;
                                                        }

                                                        if (!cellFilled)
                                                        {
                                                            <td></td>
                                                        }
                                                    }
                                                    <td></td> <!-- Action column -->
                                                </tr>
                                            }
                                        </tbody>






                                    </table>


                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const dayCells = document.querySelectorAll(".day-cell");
        const selectedDaysInput = document.getElementById("selectedDays");

        let selectedDays = [];

        dayCells.forEach(cell => {
            cell.style.cursor = "pointer";
            cell.addEventListener("click", function () {
                const day = this.textContent.trim();

                // Toggle selection
                if (selectedDays.includes(day)) {
                    selectedDays = selectedDays.filter(d => d !== day);
                    this.style.backgroundColor = ""; // Unselect
                } else {
                    selectedDays.push(day);
                    this.style.backgroundColor = "#ffc107"; // Highlight selected
                }

                // Update hidden field
                selectedDaysInput.value = selectedDays.join(",");
            });
        });

        // Optionally, handle form reset
        document.querySelector("form").addEventListener("reset", function () {
            selectedDays = [];
            selectedDaysInput.value = "";
            dayCells.forEach(cell => cell.style.backgroundColor = "");
        });
    });
</script>
<script>
    document.getElementById("seasoneOrYearSelect").addEventListener("change", function () {
        const selectedValue = this.value;
        const seasoneDiv = document.getElementById("seasoneDropdown");
        const DateDiv = document.getElementById("ChooseDate");

        if (selectedValue === "seasone") {
            seasoneDiv.style.display = "block";
            DateDiv.style.display = "block";
        }


        else {
            seasoneDiv.style.display = "none";
            DateDiv.style.display = "none";
        }
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenElement ? tokenElement.value : "";

        // Handle Delete button
        document.querySelectorAll(".delete-btn").forEach(button => {
            button.addEventListener("click", function () {
                const teamWeekendOffId = this.getAttribute("data-id");
                const employeeId = this.getAttribute("data-emp-id");

                console.log("TeamWeekendOffId:", teamWeekendOffId);
                console.log("EmployeeId:", employeeId);


                if (confirm("Are you sure you want to delete this leave?")) {
                    fetch(`/super/TeamAttendance/RemoveEmployeeFromWeekendOff/${teamWeekendOffId}/${employeeId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        }
                    })
                        .then(response => {
                            if (response.ok) {
                                location.reload();
                            } else {
                                alert('Failed to delete the leave.');
                            }
                        })
                        .catch(error => console.error('Error:', error));
                }
            });
        });
    });
</script>

<script>
    function validateForm() {
        const employeeSelect = document.getElementById("employeeSelect");
        const selectedDaysInput = document.getElementById("selectedDays");

        const selectedEmployees = Array.from(employeeSelect.selectedOptions)
            .filter(option => option.value !== "").map(option => option.value);
        const selectedDays = selectedDaysInput.value.trim();

        // Check if no employees are selected
        if (selectedEmployees.length === 0) {
            alert("Please select at least one employee.");
            employeeSelect.focus();
            return false;
        }

        // Check if no days are selected
        if (!selectedDays) {
            alert("Please select at least one day.");
            return false;
        }

        return true; // All validations passed
    }
</script>



